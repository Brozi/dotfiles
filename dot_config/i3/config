include ~/.config/i3/current-theme.conf

# Set the correct font
font pango:JetBrainsMono Nerd Font 11px

# Gaps settings
gaps inner 10
gaps outer 5

# Remove titlebars
default_border pixel 2
# default_border none
default_floating_border pixel 2
