# Should you change your keyboard layout some time, delete
# this file and re-run i3-config-wizard(1).
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

### --- Variables --- ###
set $monitor1 "HDMI-1"
set $monitor2 "DP-1"
set $scrtch_display scratchpad show; move position center;

### --- Autostart --- ###

# update dbus environment the moment i3 starts
exec --no-startup-id dbus-update-activation-environment --systemd --all

# startup the polkit agent 
exec --no-startup-id /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1

# Start XDG autostart .desktop files using dex. See also
# This starts stuff from /etc/xdg/autostart as well as ~/.config/autostart (with some exceptions)
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.
# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.

# Set X11 screensaver timeout to 20 minutes (1200 seconds)
# The time to set the pc to sleep can be changed in 
# /etc/systemd/logind.conf
exec --no-startup-id "sleep 3 && xset s 1200 1200"
exec --no-startup-id "sleep 3 && xset dpms 1200 1200 1200"

# Start xss-lock to catch the X11 timeout and systemd suspend events
exec --no-startup-id xss-lock -l -- i3lock -n -c ffffff

# Start caffeine so that the system wont sleep when watching a video
exec --no-startup-id caffeine

# Start picom compositor
exec_always --no-startup-id ~/.config/picom/scripts/launch.sh

# NetworkManager is the most popular way to manage wireless networks on Linux,
# and nm-applet is a desktop environment-independent system tray GUI for it.
# Disabled it because the cinnamon autostart has already got it
# exec --no-startup-id nm-applet

# automatically configure multimonitor setup
exec_always --no-startup-id ~/.config/scripts/screenlayout/monitor.sh

# restore the wallpaper
exec --no-startup-id nitrogen --restore

# startup polybars
# my old polybar
#exec_always --no-startup-id ~/.config/polybar/launch.sh

# new catppuccin polybar
exec_always --no-startup-id ~/.config/polybar/launch.sh --forest --side

# i3autolayout
exec_always --no-startup-id ~/.config/i3/scripts/autolayout.sh

# startup todoist
exec --no-startup-id /usr/bin/flatpak run --branch=stable --arch=x86_64 --command=todoist --file-forwarding com.todoist.Todoist --hidden @@u %U @@

# start clipboard daemon
#exec --no-startup-id /usr/bin/xfce4-clipman &

exec --no-startup-id bash -c "sleep 2 && /usr/bin/xfce4-clipman > /tmp/clipman_boot.log 2>&1"

### --- Mouse and keyboard settings --- ###

# Keyboard repeat interval
exec_always --no-startup-id xset r rate 500 33
# mouse sensitivity and acceleration
exec_always --no-startup-id xinput set-prop "pointer:Logitech G703 LS" "libinput Accel Speed"  0.20172043010752688
exec_always --no-startup-id xinput set-prop "pointer:Logitech G703 LS" "libinput Accel Profile Enabled" 0 1 0

### --- Workspace definitions --- ###

# Define names for default workspaces for which we configure key bindings later on.
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1: Terminals"
set $ws2 "2: Browsers"
set $ws3 "3: Coding"
set $ws4 "4: Communication"
set $ws5 "5: Task managment"
set $ws6 "6: Context"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Bind workspaces 1-5 to the primary monitor
workspace $ws1 output $monitor1
workspace $ws2 output $monitor1
workspace $ws3 output $monitor1
workspace $ws4 output $monitor1
workspace $ws5 output $monitor1

# Bind workspaces 6-10 to the secondary monitor
workspace $ws6 output $monitor2
workspace $ws7 output $monitor2
workspace $ws8 output $monitor2
workspace $ws9 output $monitor2
workspace $ws10 output $monitor2

# Set outer gaps to 0 for all workspaces on secondary monitor
workspace $ws6 gaps outer -6
workspace $ws7 gaps outer -6
workspace $ws8 gaps outer -6
workspace $ws9 gaps outer -6
workspace $ws10 gaps outer -6


### --- Keybinds --- ###

# set modifier keys
set $mod Mod4
# Super key
set $numlock Mod2
# numlock key
set $alt Mod1
# alt key

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status


# Open clipboard selection
bindsym $mod+c exec --no-startup-id xfce4-popup-clipman

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# Focus wrapping settings
focus_wrapping no

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# start a terminal
bindsym $mod+Return exec kitty

# kill focused window
bindsym $mod+Shift+q kill

# Open rofi launcher 
bindsym $mod+d exec --no-startup-id ~/.config/rofi/scripts/launcher_t1
# Open rofi powermenu
bindsym $mod+p exec --no-startup-id ~/.config/rofi/scripts/powermenu_t1 
# Open the screenshot Menu
bindsym Print exec --no-startup-id ~/.config/rofi/scripts/screenshot
#Open the sound Menu
bindsym $mod+Mod1+v exec --no-startup-id ~/.config/rofi/scripts/volume

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# split in horizontal orientation
bindsym $mod+g split h

# split in vertical orientation
bindsym $mod+v split v

# enter fullscreen mode for the focused container
bindsym $mod+Mod1+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+Shift+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# focus the child container
#bindsym $mod+d focus child

### --- Launcher keys --- ###
bindsym $mod+b exec --no-startup-id vivaldi --password-store=gnome-libsecret
bindsym $mod+f exec --no-startup-id kitty -e yazi

### --- Workspace keybinds --- ###

include ~/.config/i3/numpad-binds.conf

# include ~/.config/i3/normal-binds.conf

# throw the current workspace to a specific monitor
bindsym $mod+control+l move workspace to output $monitor2
bindsym $mod+control+h move workspace to output $monitor1
#bindings for the future 4 monitor layout

#bindsym $mod+control+k move workspace to output HDMI-2
#bindsym $mod+control+j move workspace to output HDMI-3

### --- Workspace rules --- ###



### --- Scratchpads --- ###

# Window rule
for_window [class="scrtch|monitor"] \
floating enable, \
move scratchpad, \
resize set 1400 800

for_window [class="(?i)todoist"] floating enable, \
resize set 1600 900, \
move position center


# Scratchpad programs
exec_always --no-startup-id pgrep -f '^kitty --class monitor' || kitty --class monitor \
--override window_margin_width=0 \
--override remember_window_size=yes \
--session ~/.config/kitty/sessions/monitor.kitty-session

exec_always --no-startup-id pgrep -f '^kitty --class kitty-scrtch' || kitty --class kitty-scrtch
exec_always --no-startup-id pgrep -f '^kitty --class yazi-scrtch' || kitty --class yazi-scrtch -e yazi


# Scratchpad binds
bindsym $mod+shift+grave [class="kitty-scrtch"] $scrtch_display
bindsym $mod+shift+w [class="monitor"] $scrtch_display
bindsym $mod+shift+f [class="yazi-scrtch"] $scrtch_display
### --- Misc keybinds --- ###

# reload the configuration file
bindsym $mod+Shift+c reload
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+Shift+r restart

# resize window (you can also use the mouse for that)
mode "resize" {
        # These bindings trigger as soon as you enter the resize mode

        # Pressing left will shrink the window’s width.
        # Pressing right will grow the window’s width.
        # Pressing up will shrink the window’s height.
        # Pressing down will grow the window’s height.
        bindsym h resize shrink width 10 px or 10 ppt
        bindsym j resize grow height 10 px or 10 ppt
        bindsym k resize shrink height 10 px or 10 ppt
        bindsym l resize grow width 10 px or 10 ppt

        # same bindings, but for the arrow keys
        bindsym Left resize shrink width 10 px or 10 ppt
        bindsym Down resize grow height 10 px or 10 ppt
        bindsym Up resize shrink height 10 px or 10 ppt
        bindsym Right resize grow width 10 px or 10 ppt

        # back to normal: Enter or Escape or $mod+r
        bindsym Return mode "default"
        bindsym Escape mode "default"
        bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

### --- Styling --- ###

